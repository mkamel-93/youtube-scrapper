# ============================================================
# 🧠 Environment and Configuration
# ============================================================
.env
.env.*
!.env.example
!.env.docker
!.env.deploy
!.env.dusk
auth.json
phpunit.xml.bak
phpunit.xml.local
/.htaccess
**/*.bkp
/*.dtmp

# ============================================================
# 🧩 Vendor & Node Dependencies
# ============================================================
/vendor/
/node_modules/
/bun.lockb

# ============================================================
# 🏗️ Build and Compiled Assets (Vite / Mix)
# ============================================================
/public/build
/public/storage
/public/hot
/public/mix-manifest.json
/public/sitemap.xml
/public/robots.txt
/.vite
/bootstrap/ssr

# ============================================================
# 🗄️ Storage and Cache (runtime-generated)
# ============================================================
/storage/app/public
/storage/framework/cache
/storage/framework/sessions
/storage/framework/views
/storage/framework/testing
/storage/framework/cache/data
/storage/logs
/storage/pail
/storage/*.key
/storage/.*
/bootstrap/cache/*

# Keep the directory structure, but ignore the contents
!storage/framework/cache/.gitignore
!storage/framework/sessions/.gitignore
!storage/framework/views/.gitignore
!storage/logs/.gitignore

# ============================================================
# 🧪 Testing and Quality Tools
# ============================================================
.phpunit.cache/
.phpunit.result.cache
.php-cs-fixer.cache
.eslintcache
/tests/Browser/screenshots/*
/tests/Browser/console/*

# ============================================================
# 🗄️ Database & Local Data
# ============================================================
*.sqlite
*.sqlite-journal
dump.rdb


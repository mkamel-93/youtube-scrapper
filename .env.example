# Start Docker Configuration

DOCKER_BASE_PATH=.docker
DOCKER_SERVICES_PATH=${DOCKER_BASE_PATH}/services

DOCKER_APP_NAME=youtube-scrapper

# The Subnet/CIDR for the bridge network
DOCKER_NETWORK_SUBNET=172.21.0.0/24

# Static IP Assignments using the prefix
DOCKER_PHP_IP=172.21.0.11

DOCKER_WEB_IP=172.21.0.12

DOCKER_DB_IP=172.21.0.13
DOCKER_PMA_IP=172.21.0.14

# DOCKER_MAIL_IP=172.21.0.15

DOCKER_REDIS_IP=172.21.0.16

# End Docker Configuration

# ----------------------------------------------------------------------------------
# Application Configuration
# ----------------------------------------------------------------------------------
APP_NAME=youtube-scrapper
APP_DEBUG=true
APP_ENV=local
APP_KEY=base64:6+g4rzezg+2IbEM/gZmBilCxmydoNSeBjyNJTk8AaMA=
APP_URL=http://${DOCKER_WEB_IP}

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

DEBUGBAR_ENABLED=true

# ----------------------------------------------------------------------------------
# Logging & Debugging
# ----------------------------------------------------------------------------------
LOG_STACK=single

ROLLBAR_ENABLED=false
ROLLBAR_TOKEN=

OH_DEAR_HEALTH_CHECK_SECRET=

# ----------------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=database
DB_PORT=3306
DB_DATABASE=${APP_NAME}
DB_USERNAME=root
DB_PASSWORD=P@ssw0rd

# -------------------------------------------------------------------------
# Services: Session, Queue, FileSystem, Broadcast and Cache
# -------------------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_COOKIE="${APP_ENV}_${APP_NAME}"
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public
BROADCAST_CONNECTION=log

CACHE_STORE=redis
TOGGLE_CACHE_DEBUG=true
TOGGLE_CACHE_ENABLED=true
TOGGLE_CACHE_TTL=3600

# ----------------------------------------------------------------------------------
# Redis Configuration
# ----------------------------------------------------------------------------------
REDIS_PREFIX="${APP_ENV}-"
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=P@ssw0rd
REDIS_PORT=6379
REDIS_DB=1
REDIS_CACHE_DB=2

# ----------------------------------------------------------------------------------
# Mail Configuration
# ----------------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="mostafakamel000@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

# -------------------------------------------------------------------------
# External Services & APIs (AWS, etc.)
# -------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ----------------------------------------------------------------------------------
# Frontend & Assets (Vite)
# ----------------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
VITE_APP_ENV="${APP_ENV}"
VITE_APP_URL="${APP_URL}"

# ----------------------------------------------------------------------------------
# Miscellaneous Security & Performance
# ----------------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS="http://${DOCKER_WEB_IP}"

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_MODEL=gemini-2.5-flash

YOUTUBE_API_KEY=
YOUTUBE_BASE_URL=https://www.googleapis.com/youtube/v3
